    {
      "name": "fs.patch",
      "parameters": {
        "$defs": {
          "_PatchEdit": {
            "properties": {
              "old_text": {
                "title": "Old Text",
                "type": "string"
              },
              "new_text": {
                "title": "New Text",
                "type": "string"
              }
            },
            "required": [
              "old_text",
              "new_text"
            ],
            "title": "_PatchEdit",
            "type": "object"
          }
        },
        "properties": {
          "path": {
            "title": "Path",
            "type": "string"
          },
          "mode": {
            "default": "edit",
            "pattern": "^(edit|create|overwrite)$",
            "title": "Mode",
            "type": "string"
          },
          "edits": {
            "items": {
              "$ref": "#/$defs/_PatchEdit"
            },
            "title": "Edits",
            "type": "array"
          },
          "content": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Content"
          }
        },
        "required": [
          "path"
        ],
        "title": "_FsPatch",
        "type": "object"
      },
      "protocol_version": "0.1.0"
    },
    {
      "name": "fs.read",
      "parameters": {
        "properties": {
          "path": {
            "title": "Path",
            "type": "string"
          },
          "start_line": {
            "anyOf": [
              {
                "minimum": 1,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Start Line"
          },
          "end_line": {
            "anyOf": [
              {
                "minimum": 1,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "End Line"
          }
        },
        "required": [
          "path"
        ],
        "title": "_FsRead",
        "type": "object"
      },
      "protocol_version": "0.1.0"
    },
