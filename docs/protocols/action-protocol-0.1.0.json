                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Glob"
          },
          "regex": {
            "default": false,
            "title": "Regex",
            "type": "boolean"
          }
        },
        "required": [
          "query"
        ],
        "title": "_FsSearch",
        "type": "object"
      },
      "protocol_version": "0.1.0"
    },
